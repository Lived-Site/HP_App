@page "/VerPersonajes"
@using Service
@using Service.DTOs
@inject PersonajeService PersonajeService
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Hogwarts - Censo Oficial</PageTitle>

<div class="hogwarts-list-container">
    <div class="parchment-list-card">
        
        <div class="list-magic-header">
            <h2 class="list-wizard-title">Registro Oficial de Habitantes</h2>
            <p class="list-wizard-subtitle">Archivos del Ministerio de Magia y el Gran Comedor</p>
        </div>

        <div class="action-bar">
            <button @onclick="IrACrear" class="btn-magic-action">
                ✨ Registrar Nuevo Individuo
            </button>
        </div>

        <div class="magic-filters-panel">
            <h4 class="filters-title">🔮 Hechizo Revelador (Filtros de Búsqueda)</h4>
            <div class="filters-grid">
                <div class="filter-group">
                    <label class="filter-label">Buscar por Nombre o Apellido:</label>
                    <input type="text" 
                           @bind="busquedaTexto" 
                           @bind:event="oninput" 
                           placeholder="Ej: Harry..." 
                           class="magic-filter-input" />
                </div>

                <div class="filter-group">
                    <label class="filter-label">Filtrar por Naturaleza:</label>
                    <select @bind="filtroTipo" class="magic-filter-select">
                        <option value="Todos">Todos los Habitantes 🌍</option>
                        <option value="Mago">Magos y Brujas 🪄</option>
                        <option value="Muggle">Muggles 👤</option>
                        <option value="Duende">Duendes 🪙</option>
                    </select>
                </div>
                

                @if (filtroTipo == "Todos" || filtroTipo == "Mago")
                {
                    <div class="filter-group animated-fade-in">
                        <label class="filter-label">Casa de Hogwarts:</label>
                        <select @bind="filtroCasa" class="magic-filter-select">
                            <option value="0">Todas las Casas 🏰</option>
                            <option value="1">Gryffindor 🦁</option>
                            <option value="2">Slytherin 🐍</option>
                            <option value="3">Hufflepuff 🦡</option>
                            <option value="4">Ravenclaw 🦅</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        <hr class="magic-divider" />

        @if (personajes == null)
        {
            <div class="magic-loading">
                <div class="wand-spinner"></div>
                <p>🔮 <em>Cargando el Gran Comedor... Desenrollando pergaminos...</em></p>
            </div>
        }
        else if (!PersonajesFiltrados.Any())
        {
            <div class="magic-empty-state">
                <p>📜 Ningún habitante coincide con los criterios del Ministerio. ¿Habrán usado una Capa de Invisibilidad?</p>
            </div>
        }
        else
        {
            <div class="characters-grid">
                @foreach (var personaje in PersonajesFiltrados)
                {
                    <div class="character-card">
            
                        <div class="card-main-content">
                            <div class="card-avatar-zone">
                                <div class="avatar-ring">
                                    <img src="@personaje.FotoUrl" 
                                         alt="Foto de @personaje.Nombre" 
                                         @onclick="() => MostrarFotoGrande(personaje.FotoUrl)"
                                         class="character-avatar-img" />
                                </div>
                            </div>
                
                            <div class="card-info-zone">
                                <h3 class="character-name">@personaje.Nombre @personaje.Apellido</h3>
                    
                                <span class="badge-raza @personaje.Tipo.ToLower()">
                                    @switch (personaje.Tipo)
                                    {
                                        case "Mago": <span>🪄 Mago / Bruja</span> break;
                                        case "Muggle": <span>👤 Muggle</span> break;
                                        case "Duende": <span>🪙 Duende</span> break;
                                        default: <span>🔮 Desconocido</span> break;
                                    }
                                </span>
                            </div>
                        </div>

                        @if (personaje.PersonajeCreadoPorElUsuario)
                        {
                            <div class="card-action-zone">
                                <button @onclick="() => EditarPersonaje(personaje.Id)" class="btn-magic-edit">
                                    🪄 Editar
                                </button>
                            </div>
                        }
            
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(fotoGrandeUrl))
{
    <div @onclick="CerrarFotoGrande" class="magic-modal-overlay">
        <div class="magic-modal-content" @onclick:stopPropagation>
            <div class="portrait-frame">
                <img src="@fotoGrandeUrl" alt="Retrato oficial ampliado" class="portrait-large-img" />
            </div>
            <button @onclick="CerrarFotoGrande" class="btn-magic-close">
                ❌ Cerrar Retrato
            </button>
        </div>
    </div>
}



@code {
    private IEnumerable<PersonajeDto> personajes;
    private string fotoGrandeUrl = string.Empty;

    // Variables de estado para enlazar los filtros
    private string busquedaTexto = string.Empty;
    private string filtroTipo = "Todos";
    private int filtroCasa = 0;

    protected override void OnInitialized()
    {
        personajes = PersonajeService.ObtenerTodosLosPersonajes();
    }
    private IEnumerable<PersonajeDto> PersonajesFiltrados
    {
        get
        {
            if (personajes == null) return Enumerable.Empty<PersonajeDto>();

            return personajes.Where(p =>
                (filtroTipo == "Todos" || p.Tipo.Equals(filtroTipo, StringComparison.OrdinalIgnoreCase)) &&
                
                (string.IsNullOrWhiteSpace(busquedaTexto) || 
                 p.Nombre.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase) || 
                 p.Apellido.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase)) &&
                
                (filtroCasa == 0 || p.IdCasa == filtroCasa)
            );
        }
    }

    private void MostrarFotoGrande(string url) => fotoGrandeUrl = url;
    private void CerrarFotoGrande() => fotoGrandeUrl = string.Empty;
    private void IrACrear() => NavManager.NavigateTo("/crearPersonaje");

    private void EditarPersonaje(int id)
    {
        NavManager.NavigateTo($"/EditarPersonaje/{id}");
    }

}



<style>
    .hogwarts-list-container {
        display: flex;
        justify-content: center;
        padding: 2rem 1rem;
        background-color: #1a1510;
        min-height: 100vh;
        font-family: 'Cinzel', 'Georgia', serif;
    }

    .parchment-list-card {
        background: #f4ecd8;
        background-image: radial-gradient(rgba(0, 0, 0, 0.05) 15%, transparent 16%),
                          radial-gradient(rgba(0, 0, 0, 0.05) 15%, transparent 16%);
        background-size: 60px 60px;
        background-position: 0 0, 30px 30px;
        border: 4px solid #6b532c;
        border-image: linear-gradient(to bottom, #8a6d3b, #4a3618) 1;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), inset 0 0 40px rgba(74, 54, 24, 0.2);
        padding: 2.5rem;
        width: 100%;
        max-width: 950px;
        color: #2b1f10;
    }

    .list-magic-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }
    .list-wizard-title {
        font-size: 2.2rem;
        color: #4a1506;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        margin-bottom: 0.3rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .list-wizard-subtitle {
        font-style: italic;
        color: #6b532c;
        font-size: 1rem;
    }

    /* PANEL DE FILTROS */
    .magic-filters-panel {
        background: rgba(74, 54, 24, 0.08);
        border: 1px dashed #8a6d3b;
        border-radius: 8px;
        padding: 1.2rem;
        margin-bottom: 1.5rem;
    }
    .filters-title {
        margin-top: 0;
        margin-bottom: 1rem;
        color: #4a1506;
        font-size: 1.1rem;
        font-weight: bold;
    }
    .filters-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    @@media (max-width: 600px) {
        .filters-grid { grid-template-columns: 1fr; gap: 1rem; }
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .filter-label {
        font-size: 0.85rem;
        font-weight: bold;
        color: #4a3618;
    }
    .magic-filter-input, .magic-filter-select {
        background-color: #fffcf2;
        border: 1px solid #bba374;
        border-radius: 4px;
        padding: 0.5rem;
        color: #2b1f10;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .magic-filter-input:focus, .magic-filter-select:focus {
        border-color: #741b12;
        box-shadow: 0 0 5px rgba(116, 27, 18, 0.2);
    }

    .magic-divider {
        border: 0;
        height: 2px;
        background-image: linear-gradient(to right, transparent, #8a6d3b, transparent);
        margin: 1.5rem 0;
    }

    .action-bar {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
    }
    .btn-magic-action {
        background: linear-gradient(135deg, #741b12 0%, #4a1506 100%);
        color: #f4ecd8;
        border: 2px solid #8a6d3b;
        padding: 0.75rem 2rem;
        font-size: 1.1rem;
        font-weight: bold;
        border-radius: 30px;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .btn-magic-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 15px rgba(116, 27, 18, 0.4);
        background: linear-gradient(135deg, #8a251a 0%, #5a1b0b 100%);
    }

    /* GRILLA Y TARJETAS MODIFICADAS */
    .characters-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
    }

    .character-card {
        background: rgba(255, 252, 242, 0.6);
        border: 1px solid #d3c4a3;
        border-radius: 8px;
        padding: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: space-between; /* Empuja el botón al extremo derecho */
        gap: 1rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: transform 0.2s, box-shadow 0.2s;
        min-height: 115px; /* Asegura simetría visual en todas las tarjetas */
    }
    .character-card:hover {
        transform: scale(1.02);
        box-shadow: 0 8px 15px rgba(74, 54, 24, 0.15);
        background: rgba(255, 252, 242, 0.9);
        border-color: #8a6d3b;
    }

    .card-main-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-grow: 1; /* Absorbe el espacio disponible sin apretar los componentes */
    }

    .avatar-ring {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #8a6d3b, #4a3618);
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        flex-shrink: 0; /* Evita que el anillo del avatar se deforme */
    }
    .character-avatar-img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        background-color: white;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .character-avatar-img:hover {
        transform: scale(1.08);
    }

    .card-info-zone {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        justify-content: center;
    }
    .character-name {
        margin: 0;
        font-size: 1.15rem;
        color: #2b1f10;
        font-weight: bold;
        line-height: 1.2;
    }

    .badge-raza {
        display: inline-flex;
        align-items: center;
        white-space: nowrap; /* Impide de forma absoluta el colapso vertical */
        padding: 0.3rem 0.6rem;
        font-size: 0.75rem;
        font-weight: bold;
        border-radius: 4px;
        text-transform: uppercase;
        width: fit-content;
        letter-spacing: 0.5px;
        border: 1px solid transparent;
    }
    .badge-raza.mago { background-color: #e3d2ff; color: #3b1480; border-color: #b799fa; }
    .badge-raza.muggle { background-color: #e2e8f0; color: #334155; border-color: #cbd5e1; }
    .badge-raza.duende { background-color: #fef3c7; color: #78350f; border-color: #fcd34d; }

    /* BOTÓN EDITAR ESTILIZADO */
    .card-action-zone {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }
    .btn-magic-edit {
        background: linear-gradient(135deg, #5a1b0b 0%, #4a1506 100%);
        color: #f4ecd8;
        border: 1px solid #8a6d3b;
        padding: 0.5rem 0.9rem;
        font-size: 0.85rem;
        font-weight: bold;
        border-radius: 6px;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s ease;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .btn-magic-edit:hover {
        background: linear-gradient(135deg, #741b12 0%, #5a1b0b 100%);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(116, 27, 18, 0.3);
    }

    /* ELEMENTOS AUXILIARES Y MODAL */
    .magic-loading, .magic-empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #6b532c;
        font-style: italic;
    }
    .wand-spinner {
        margin: 0 auto 1rem auto;
        width: 40px;
        height: 40px;
        border: 4px solid #d3c4a3;
        border-top: 4px solid #741b12;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .magic-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 12, 9, 0.85);
        backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        animation: fadeIn 0.25s ease-out forwards;
    }
    .magic-modal-content { text-align: center; }
    .portrait-frame {
        padding: 8px;
        background: linear-gradient(135deg, #ccae70 0%, #7c5a24 50%, #4a3311 100%);
        border-radius: 8px;
        box-shadow: 0px 15px 35px rgba(0,0,0,0.7);
        animation: scaleUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .portrait-large-img {
        width: 320px;
        height: 320px;
        object-fit: cover;
        display: block;
        border: 2px solid #1a1510;
        border-radius: 4px;
    }
    .btn-magic-close {
        margin-top: 1.5rem;
        background: #f4ecd8;
        color: #4a1506;
        border: 2px solid #8a6d3b;
        padding: 0.5rem 1.5rem;
        border-radius: 20px;
        cursor: pointer;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: transform 0.2s;
    }
    .btn-magic-close:hover { transform: scale(1.05); background: #fff; }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes scaleUp { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

