@page "/VerPersonajes"
@using Service
@using Service.DTOs
@inject PersonajeService PersonajeService
@inject NavigationManager NavManager
@rendermode InteractiveServer

<h3>Lista de Personajes del Mundo Mágico</h3>

<button @onclick="IrACrear" style="margin-bottom: 15px;">Crear Nuevo Personaje</button>

@if (personajes == null)
{
    <p><em>Cargando el Gran Comedor...</em></p>
}
else if (!personajes.Any())
{
    <p>No hay personajes registrados en el mundo mágico todavía.</p>
}
else
{
    <table class="table" style="vertical-align: middle;">
        <thead>
        <tr>
            <th style="width: 80px;">Avatar</th>
            <th>Nombre</th>
            <th>Apellido</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var personaje in personajes)
        {
            <tr>
                <td>
                    <img src="@personaje.FotoUrl" 
                         alt="Foto de @personaje.Nombre" 
                         @onclick="() => MostrarFotoGrande(personaje.FotoUrl)"
                         style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid #ccc; background-color: white; cursor: pointer;" />
                </td>
                <td>@personaje.Nombre</td>
                <td>@personaje.Apellido</td>
            </tr>
        }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(fotoGrandeUrl))
{
    <div @onclick="CerrarFotoGrande" 
         style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 9999; animation: fadeIn 0.2s ease-out;">
        
        <div style="text-align: center; position: relative;" @onclick:stopPropagation>
            <img src="@fotoGrandeUrl" 
                 alt="Foto grande" 
                 style="width: 300px; height: 300px; border-radius: 50%; object-fit: cover; border: 5px solid white; box-shadow: 0px 4px 20px rgba(0,0,0,0.5); animation: scaleUp 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);" />
            
            <button @onclick="CerrarFotoGrande" 
                    style="display: block; margin: 15px auto 0 auto; background: white; border: none; padding: 5px 15px; border-radius: 20px; cursor: pointer; font-weight: bold;">
                Cerrar
            </button>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from { background: rgba(0,0,0,0); }
        to { background: rgba(0,0,0,0.7); }
    }
    @@keyframes scaleUp {
        from { transform: scale(0.7); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    private IEnumerable<PersonajeDto> personajes;
    
    private string fotoGrandeUrl = string.Empty;

    protected override void OnInitialized()
    {
        personajes = PersonajeService.ObtenerTodosLosPersonajes();
    }

    private void MostrarFotoGrande(string url)
    {
        fotoGrandeUrl = url;
    }

    private void CerrarFotoGrande()
    {
        fotoGrandeUrl = string.Empty;
    }

    private void IrACrear()
    {
        NavManager.NavigateTo("/crearPersonaje");
    }
}